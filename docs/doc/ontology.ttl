<https://hcis.io/ontology/aicapstone/2026/group03/basket01> rdf:type owl:NamedIndividual ,
                                                                     <https://hcis.io/ontology/aicapstone/2026/Basket> ;
                                                            <https://hcis.io/ontology/aicapstone/2026/hasAffordance> <https://hcis.io/ontology/aicapstone/2026/group03/aff_basket01_contain> ;
                                                            <https://hcis.io/ontology/aicapstone/2026/hasTaskRole> <https://hcis.io/ontology/aicapstone/2026/ContainerTarget> ;
