    <rdf:Description rdf:about="https://hcis.io/ontology/aicapstone/2026/CollectableObject">
        <rdfs:comment xml:lang="en">A task role for an object that should be collected into another object or location.</rdfs:comment>
        <rdfs:label xml:lang="en">collectable object</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://hcis.io/ontology/aicapstone/2026/ContainerTarget">
        <rdfs:comment xml:lang="en">A task role for an object that receives or contains other objects.</rdfs:comment>
        <rdfs:label xml:lang="en">container target</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://hcis.io/ontology/aicapstone/2026/ReferenceObject">
        <rdfs:comment xml:lang="en">A task role for an object used as a spatial or semantic reference for arranging other objects.</rdfs:comment>
        <rdfs:label xml:lang="en">reference object</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://hcis.io/ontology/aicapstone/2026/TargetObject">
        <rdfs:comment xml:lang="en">A task role for an object that is directly acted upon or manipulated.</rdfs:comment>
        <rdfs:label xml:lang="en">target object</rdfs:label>
    </rdf:Description>
