<?xml version="1.0"?>
<rdf:RDF xmlns="https://hcis.io/ontology/aicapstone/2026/group03#"
     xml:base="https://hcis.io/ontology/aicapstone/2026/group03"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:foaf="http://xmlns.com/foaf/0.1/"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:vann="http://purl.org/vocab/vann/"
     xmlns:terms="http://purl.org/dc/terms/"
     xmlns:aicapstone="https://hcis.io/ontology/aicapstone/2026/">
    <owl:Ontology rdf:about="https://hcis.io/ontology/aicapstone/2026/group03">
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-05-31</terms:created>
        <terms:creator rdf:resource="https://hcis.io/ontology/aicapstone/2026/group03/group03"/>
        <terms:description xml:lang="en">A group ontology that grounds perceived task objects (cups, cutlery, plate, toy blocks, basket) as typed, role-bearing, affordance-carrying individuals, so that an OWL DL reasoner can infer which objects are graspable.</terms:description>
        <terms:license rdf:resource="https://creativecommons.org/licenses/by/4.0/"/>
        <terms:title xml:lang="en">AI Capstone 2026 - Group 03 Semantic Grounding Ontology</terms:title>
        <vann:preferredNamespacePrefix>g03</vann:preferredNamespacePrefix>
        <vann:preferredNamespaceUri>https://hcis.io/ontology/aicapstone/2026/group03/</vann:preferredNamespaceUri>
        <rdfs:comment xml:lang="en">Group 03 submission for Homework 5. Imports the shared course vocabulary, supplies the OWL definition of cap:GraspableObject, and declares the environment instances used to infer graspability.</rdfs:comment>
        <rdfs:label xml:lang="en">AI Capstone 2026 - Group 03 Semantic Grounding Ontology</rdfs:label>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://purl.org/dc/terms/created -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/created"/>
    


    <!-- http://purl.org/dc/terms/creator -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/creator"/>
    


    <!-- http://purl.org/dc/terms/description -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/description"/>
    


    <!-- http://purl.org/dc/terms/license -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/license"/>
    


    <!-- http://purl.org/dc/terms/title -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/title"/>
    


    <!-- http://purl.org/vocab/vann/preferredNamespacePrefix -->


    <owl:AnnotationProperty rdf:about="http://purl.org/vocab/vann/preferredNamespacePrefix"/>
    


    <!-- http://purl.org/vocab/vann/preferredNamespaceUri -->


    <owl:AnnotationProperty rdf:about="http://purl.org/vocab/vann/preferredNamespaceUri"/>
    


    <!-- http://xmlns.com/foaf/0.1/mbox -->


    <owl:AnnotationProperty rdf:about="http://xmlns.com/foaf/0.1/mbox"/>
    


    <!-- http://xmlns.com/foaf/0.1/member -->


    <owl:AnnotationProperty rdf:about="http://xmlns.com/foaf/0.1/member"/>
    


    <!-- http://xmlns.com/foaf/0.1/name -->


    <owl:AnnotationProperty rdf:about="http://xmlns.com/foaf/0.1/name"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Datatypes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.w3.org/2001/XMLSchema#date -->


    <rdfs:Datatype rdf:about="http://www.w3.org/2001/XMLSchema#date"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- https://hcis.io/ontology/aicapstone/2026/canBeManipulatedBy -->


    <owl:ObjectProperty rdf:about="https://hcis.io/ontology/aicapstone/2026/canBeManipulatedBy">
        <rdfs:domain rdf:resource="https://hcis.io/ontology/aicapstone/2026/PhysicalObject"/>
        <rdfs:range rdf:resource="https://hcis.io/ontology/aicapstone/2026/EndEffector"/>
        <rdfs:comment xml:lang="en">Relates a physical object to an end effector capable of manipulating it.</rdfs:comment>
        <rdfs:label xml:lang="en">can be manipulated by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://hcis.io/ontology/aicapstone/2026/hasAffordance -->


    <owl:ObjectProperty rdf:about="https://hcis.io/ontology/aicapstone/2026/hasAffordance">
        <rdfs:domain rdf:resource="https://hcis.io/ontology/aicapstone/2026/PhysicalObject"/>
        <rdfs:range rdf:resource="https://hcis.io/ontology/aicapstone/2026/Affordance"/>
        <rdfs:comment xml:lang="en">Relates a physical object to an affordance associated with that object in the task context.</rdfs:comment>
        <rdfs:label xml:lang="en">has affordance</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://hcis.io/ontology/aicapstone/2026/hasReferenceObject -->


    <owl:ObjectProperty rdf:about="https://hcis.io/ontology/aicapstone/2026/hasReferenceObject">
        <rdfs:domain rdf:resource="https://hcis.io/ontology/aicapstone/2026/Task"/>
        <rdfs:range rdf:resource="https://hcis.io/ontology/aicapstone/2026/PhysicalObject"/>
        <rdfs:comment xml:lang="en">Relates a task to a physical object used as a spatial or semantic reference.</rdfs:comment>
        <rdfs:label xml:lang="en">has reference object</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://hcis.io/ontology/aicapstone/2026/hasTargetObject -->


    <owl:ObjectProperty rdf:about="https://hcis.io/ontology/aicapstone/2026/hasTargetObject">
        <rdfs:domain rdf:resource="https://hcis.io/ontology/aicapstone/2026/Task"/>
        <rdfs:range rdf:resource="https://hcis.io/ontology/aicapstone/2026/PhysicalObject"/>
        <rdfs:comment xml:lang="en">Relates a task to a physical object that is directly acted upon in that task.</rdfs:comment>
        <rdfs:label xml:lang="en">has target object</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://hcis.io/ontology/aicapstone/2026/hasTaskRole -->


    <owl:ObjectProperty rdf:about="https://hcis.io/ontology/aicapstone/2026/hasTaskRole">
        <rdfs:domain rdf:resource="https://hcis.io/ontology/aicapstone/2026/PhysicalObject"/>
        <rdfs:range rdf:resource="https://hcis.io/ontology/aicapstone/2026/TaskRole"/>
        <rdfs:comment xml:lang="en">Relates a physical object to the role it plays in a task.</rdfs:comment>
        <rdfs:label xml:lang="en">has task role</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- https://hcis.io/ontology/aicapstone/2026/hasApproxWidth -->


    <owl:DatatypeProperty rdf:about="https://hcis.io/ontology/aicapstone/2026/hasApproxWidth">
        <rdfs:domain rdf:resource="https://hcis.io/ontology/aicapstone/2026/PhysicalObject"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment xml:lang="en">Records an approximate object width, which may be useful for checking whether an object fits within a gripper capability.</rdfs:comment>
        <rdfs:label xml:lang="en">has approximate width</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://hcis.io/ontology/aicapstone/2026/hasColor -->


    <owl:DatatypeProperty rdf:about="https://hcis.io/ontology/aicapstone/2026/hasColor">
        <rdfs:domain rdf:resource="https://hcis.io/ontology/aicapstone/2026/PhysicalObject"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Records the perceived or assigned color of a physical object.</rdfs:comment>
        <rdfs:label xml:lang="en">has color</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://hcis.io/ontology/aicapstone/2026/hasObjectLabel -->


    <owl:DatatypeProperty rdf:about="https://hcis.io/ontology/aicapstone/2026/hasObjectLabel">
        <rdfs:domain rdf:resource="https://hcis.io/ontology/aicapstone/2026/PhysicalObject"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Records the object label used by perception, simulation, or task documentation.</rdfs:comment>
        <rdfs:label xml:lang="en">has object label</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://hcis.io/ontology/aicapstone/2026/hasPoseFrame -->


    <owl:DatatypeProperty rdf:about="https://hcis.io/ontology/aicapstone/2026/hasPoseFrame">
        <rdfs:domain rdf:resource="https://hcis.io/ontology/aicapstone/2026/PhysicalObject"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Links an ontology individual to a coordinate frame or pose-frame identifier used in perception, reconstruction, or simulation.</rdfs:comment>
        <rdfs:label xml:lang="en">has pose frame</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://xmlns.com/foaf/0.1/Group -->


    <owl:Class rdf:about="http://xmlns.com/foaf/0.1/Group"/>
    


    <!-- http://xmlns.com/foaf/0.1/Person -->


    <owl:Class rdf:about="http://xmlns.com/foaf/0.1/Person"/>
    


    <!-- https://hcis.io/ontology/aicapstone/2026/Affordance -->


    <owl:Class rdf:about="https://hcis.io/ontology/aicapstone/2026/Affordance">
        <rdfs:comment xml:lang="en">An action possibility associated with an object in relation to a robot capability and task context.</rdfs:comment>
        <rdfs:label xml:lang="en">affordance</rdfs:label>
    </owl:Class>
    


    <!-- https://hcis.io/ontology/aicapstone/2026/Basket -->


    <owl:Class rdf:about="https://hcis.io/ontology/aicapstone/2026/Basket">
        <rdfs:subClassOf rdf:resource="https://hcis.io/ontology/aicapstone/2026/PhysicalObject"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://hcis.io/ontology/aicapstone/2026/hasAffordance"/>
                <owl:someValuesFrom rdf:resource="https://hcis.io/ontology/aicapstone/2026/ContainmentAffordance"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A container target used to receive toy blocks in the toy-block-collection task.</rdfs:comment>
        <rdfs:label xml:lang="en">basket</rdfs:label>
    </owl:Class>
    


    <!-- https://hcis.io/ontology/aicapstone/2026/CollectableObject -->


    <owl:Class rdf:about="https://hcis.io/ontology/aicapstone/2026/CollectableObject">
        <rdfs:subClassOf rdf:resource="https://hcis.io/ontology/aicapstone/2026/TaskRole"/>
    </owl:Class>
    


    <!-- https://hcis.io/ontology/aicapstone/2026/ContainerTarget -->


    <owl:Class rdf:about="https://hcis.io/ontology/aicapstone/2026/ContainerTarget">
        <rdfs:subClassOf rdf:resource="https://hcis.io/ontology/aicapstone/2026/TaskRole"/>
    </owl:Class>
    


    <!-- https://hcis.io/ontology/aicapstone/2026/ContainmentAffordance -->


    <owl:Class rdf:about="https://hcis.io/ontology/aicapstone/2026/ContainmentAffordance">
        <rdfs:subClassOf rdf:resource="https://hcis.io/ontology/aicapstone/2026/Affordance"/>
        <rdfs:comment xml:lang="en">An affordance by which an object can contain or receive other objects.</rdfs:comment>
        <rdfs:label xml:lang="en">containment affordance</rdfs:label>
    </owl:Class>
    


    <!-- https://hcis.io/ontology/aicapstone/2026/Cup -->


    <owl:Class rdf:about="https://hcis.io/ontology/aicapstone/2026/Cup">
        <rdfs:subClassOf rdf:resource="https://hcis.io/ontology/aicapstone/2026/PhysicalObject"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://hcis.io/ontology/aicapstone/2026/hasAffordance"/>
                <owl:someValuesFrom rdf:resource="https://hcis.io/ontology/aicapstone/2026/GraspingAffordance"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://hcis.io/ontology/aicapstone/2026/hasAffordance"/>
                <owl:someValuesFrom rdf:resource="https://hcis.io/ontology/aicapstone/2026/StackabilityAffordance"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A container-like object used in the cup-stacking task.</rdfs:comment>
        <rdfs:label xml:lang="en">cup</rdfs:label>
    </owl:Class>
    


    <!-- https://hcis.io/ontology/aicapstone/2026/EndEffector -->


    <owl:Class rdf:about="https://hcis.io/ontology/aicapstone/2026/EndEffector">
        <rdfs:comment xml:lang="en">A robot component used to physically interact with objects, such as a gripper.</rdfs:comment>
        <rdfs:label xml:lang="en">end effector</rdfs:label>
    </owl:Class>
    


    <!-- https://hcis.io/ontology/aicapstone/2026/Fork -->


    <owl:Class rdf:about="https://hcis.io/ontology/aicapstone/2026/Fork">
        <rdfs:subClassOf rdf:resource="https://hcis.io/ontology/aicapstone/2026/PhysicalObject"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://hcis.io/ontology/aicapstone/2026/hasAffordance"/>
                <owl:someValuesFrom rdf:resource="https://hcis.io/ontology/aicapstone/2026/GraspingAffordance"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A cutlery object to be placed in the cutlery-arrangement task.</rdfs:comment>
        <rdfs:label xml:lang="en">fork</rdfs:label>
    </owl:Class>
    


    <!-- https://hcis.io/ontology/aicapstone/2026/GraspableObject -->


    <owl:Class rdf:about="https://hcis.io/ontology/aicapstone/2026/GraspableObject">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://hcis.io/ontology/aicapstone/2026/PhysicalObject"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://hcis.io/ontology/aicapstone/2026/hasAffordance"/>
                        <owl:someValuesFrom rdf:resource="https://hcis.io/ontology/aicapstone/2026/GraspingAffordance"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:comment xml:lang="en">A physical object inferred to afford grasping by a robot end effector in the task context. Membership is derived by reasoning, not asserted.</rdfs:comment>
        <rdfs:label xml:lang="en">graspable object</rdfs:label>
    </owl:Class>
    


    <!-- https://hcis.io/ontology/aicapstone/2026/GraspingAffordance -->


    <owl:Class rdf:about="https://hcis.io/ontology/aicapstone/2026/GraspingAffordance">
        <rdfs:subClassOf rdf:resource="https://hcis.io/ontology/aicapstone/2026/Affordance"/>
        <rdfs:comment xml:lang="en">An affordance by which an object may be grasped, held, lifted, or repositioned by a robot gripper.</rdfs:comment>
        <rdfs:label xml:lang="en">grasping affordance</rdfs:label>
    </owl:Class>
    


    <!-- https://hcis.io/ontology/aicapstone/2026/Knife -->


    <owl:Class rdf:about="https://hcis.io/ontology/aicapstone/2026/Knife">
        <rdfs:subClassOf rdf:resource="https://hcis.io/ontology/aicapstone/2026/PhysicalObject"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://hcis.io/ontology/aicapstone/2026/hasAffordance"/>
                <owl:someValuesFrom rdf:resource="https://hcis.io/ontology/aicapstone/2026/GraspingAffordance"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A cutlery object to be placed in the cutlery-arrangement task.</rdfs:comment>
        <rdfs:label xml:lang="en">knife</rdfs:label>
    </owl:Class>
    


    <!-- https://hcis.io/ontology/aicapstone/2026/ManipulationTask -->


    <owl:Class rdf:about="https://hcis.io/ontology/aicapstone/2026/ManipulationTask">
        <rdfs:subClassOf rdf:resource="https://hcis.io/ontology/aicapstone/2026/Task"/>
        <rdfs:comment xml:lang="en">A task in which a robot changes the pose, state, or arrangement of physical objects.</rdfs:comment>
        <rdfs:label xml:lang="en">manipulation task</rdfs:label>
    </owl:Class>
    


    <!-- https://hcis.io/ontology/aicapstone/2026/PhysicalObject -->


    <owl:Class rdf:about="https://hcis.io/ontology/aicapstone/2026/PhysicalObject">
        <rdfs:comment xml:lang="en">A material object in the task environment that may be perceived, manipulated, used as a reference object, or assigned a task role.</rdfs:comment>
        <rdfs:label xml:lang="en">physical object</rdfs:label>
    </owl:Class>
    


    <!-- https://hcis.io/ontology/aicapstone/2026/Plate -->


    <owl:Class rdf:about="https://hcis.io/ontology/aicapstone/2026/Plate">
        <rdfs:subClassOf rdf:resource="https://hcis.io/ontology/aicapstone/2026/PhysicalObject"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://hcis.io/ontology/aicapstone/2026/hasAffordance"/>
                <owl:someValuesFrom rdf:resource="https://hcis.io/ontology/aicapstone/2026/SupportAffordance"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A reference object used for arranging cutlery in the cutlery-arrangement task.</rdfs:comment>
        <rdfs:label xml:lang="en">plate</rdfs:label>
    </owl:Class>
    


    <!-- https://hcis.io/ontology/aicapstone/2026/ReferenceObject -->


    <owl:Class rdf:about="https://hcis.io/ontology/aicapstone/2026/ReferenceObject">
        <rdfs:subClassOf rdf:resource="https://hcis.io/ontology/aicapstone/2026/TaskRole"/>
    </owl:Class>
    


    <!-- https://hcis.io/ontology/aicapstone/2026/RobotAgent -->


    <owl:Class rdf:about="https://hcis.io/ontology/aicapstone/2026/RobotAgent">
        <rdfs:comment xml:lang="en">A robot or robot-controlled agent that can perceive objects, reason over the ontology, and act in the task environment.</rdfs:comment>
        <rdfs:label xml:lang="en">robot agent</rdfs:label>
    </owl:Class>
    


    <!-- https://hcis.io/ontology/aicapstone/2026/StackabilityAffordance -->


    <owl:Class rdf:about="https://hcis.io/ontology/aicapstone/2026/StackabilityAffordance">
        <rdfs:subClassOf rdf:resource="https://hcis.io/ontology/aicapstone/2026/Affordance"/>
        <rdfs:comment xml:lang="en">An affordance by which an object can participate in a stacking relation with another object.</rdfs:comment>
        <rdfs:label xml:lang="en">stackability affordance</rdfs:label>
    </owl:Class>
    


    <!-- https://hcis.io/ontology/aicapstone/2026/SupportAffordance -->


    <owl:Class rdf:about="https://hcis.io/ontology/aicapstone/2026/SupportAffordance">
        <rdfs:subClassOf rdf:resource="https://hcis.io/ontology/aicapstone/2026/Affordance"/>
        <rdfs:comment xml:lang="en">An affordance by which an object can support the placement or arrangement of other objects.</rdfs:comment>
        <rdfs:label xml:lang="en">support affordance</rdfs:label>
    </owl:Class>
    


    <!-- https://hcis.io/ontology/aicapstone/2026/TargetObject -->


    <owl:Class rdf:about="https://hcis.io/ontology/aicapstone/2026/TargetObject">
        <rdfs:subClassOf rdf:resource="https://hcis.io/ontology/aicapstone/2026/TaskRole"/>
    </owl:Class>
    


    <!-- https://hcis.io/ontology/aicapstone/2026/Task -->


    <owl:Class rdf:about="https://hcis.io/ontology/aicapstone/2026/Task">
        <rdfs:comment xml:lang="en">A goal-directed activity to be performed or evaluated in the course project.</rdfs:comment>
        <rdfs:label xml:lang="en">task</rdfs:label>
    </owl:Class>
    


    <!-- https://hcis.io/ontology/aicapstone/2026/TaskRole -->


    <owl:Class rdf:about="https://hcis.io/ontology/aicapstone/2026/TaskRole">
        <rdfs:comment xml:lang="en">A role that an object plays within a task.</rdfs:comment>
        <rdfs:label xml:lang="en">task role</rdfs:label>
    </owl:Class>
    


    <!-- https://hcis.io/ontology/aicapstone/2026/ToyBlock -->


    <owl:Class rdf:about="https://hcis.io/ontology/aicapstone/2026/ToyBlock">
        <rdfs:subClassOf rdf:resource="https://hcis.io/ontology/aicapstone/2026/PhysicalObject"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://hcis.io/ontology/aicapstone/2026/hasAffordance"/>
                <owl:someValuesFrom rdf:resource="https://hcis.io/ontology/aicapstone/2026/GraspingAffordance"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A small object to be collected into the basket in the toy-block-collection task.</rdfs:comment>
        <rdfs:label xml:lang="en">toy block</rdfs:label>
    </owl:Class>
    


