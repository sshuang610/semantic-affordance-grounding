    //
    // Individuals
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- https://hcis.io/ontology/aicapstone/2026/CollectableObject -->


    <owl:NamedIndividual rdf:about="https://hcis.io/ontology/aicapstone/2026/CollectableObject"/>
    


    <!-- https://hcis.io/ontology/aicapstone/2026/ContainerTarget -->


    <owl:NamedIndividual rdf:about="https://hcis.io/ontology/aicapstone/2026/ContainerTarget"/>
    


    <!-- https://hcis.io/ontology/aicapstone/2026/ReferenceObject -->


    <owl:NamedIndividual rdf:about="https://hcis.io/ontology/aicapstone/2026/ReferenceObject"/>
    


    <!-- https://hcis.io/ontology/aicapstone/2026/TargetObject -->


    <owl:NamedIndividual rdf:about="https://hcis.io/ontology/aicapstone/2026/TargetObject"/>
    


    <!-- https://hcis.io/ontology/aicapstone/2026/ccyont -->


    <owl:NamedIndividual rdf:about="https://hcis.io/ontology/aicapstone/2026/ccyont">
        <rdf:type rdf:resource="http://xmlns.com/foaf/0.1/Person"/>
        <foaf:mbox rdf:resource="mailto:ccy@hptp.org"/>
        <foaf:name xml:lang="en">Chun-yien Chang</foaf:name>
    </owl:NamedIndividual>
    


    <!-- https://hcis.io/ontology/aicapstone/2026/group03/aff_basket01_contain -->


    <owl:NamedIndividual rdf:about="https://hcis.io/ontology/aicapstone/2026/group03/aff_basket01_contain">
        <rdf:type rdf:resource="https://hcis.io/ontology/aicapstone/2026/ContainmentAffordance"/>
        <rdfs:label xml:lang="en">containment affordance of basket 01</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://hcis.io/ontology/aicapstone/2026/group03/aff_block01_grasp -->


    <owl:NamedIndividual rdf:about="https://hcis.io/ontology/aicapstone/2026/group03/aff_block01_grasp">
        <rdf:type rdf:resource="https://hcis.io/ontology/aicapstone/2026/GraspingAffordance"/>
        <rdfs:label xml:lang="en">grasping affordance of toy block 01</rdfs:label>
    </owl:NamedIndividual>
    


