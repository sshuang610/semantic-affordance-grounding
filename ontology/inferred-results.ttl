cap:canBeManipulatedBy a owl:ObjectProperty ;
    rdfs:label "can be manipulated by"@en ;
    rdfs:comment "Relates a physical object to an end effector capable of manipulating it."@en ;
    rdfs:domain owl:Thing,
        cap:PhysicalObject ;
    rdfs:range owl:Thing,
        cap:EndEffector ;
    rdfs:subPropertyOf cap:canBeManipulatedBy ;
    owl:equivalentProperty cap:canBeManipulatedBy ;
    owl:sameAs cap:canBeManipulatedBy .

cap:hasApproxWidth a owl:DatatypeProperty ;
    rdfs:label "has approximate width"@en ;
    rdfs:comment "Records an approximate object width, which may be useful for checking whether an object fits within a gripper capability."@en ;
    rdfs:domain owl:Thing,
        cap:PhysicalObject ;
    rdfs:range xsd:decimal ;
    rdfs:subPropertyOf cap:hasApproxWidth ;
    owl:equivalentProperty cap:hasApproxWidth ;
    owl:sameAs cap:hasApproxWidth .

cap:hasColor a owl:DatatypeProperty ;
    rdfs:label "has color"@en ;
    rdfs:comment "Records the perceived or assigned color of a physical object."@en ;
    rdfs:domain owl:Thing,
        cap:PhysicalObject ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf cap:hasColor ;
    owl:equivalentProperty cap:hasColor ;
    owl:sameAs cap:hasColor .

cap:hasObjectLabel a owl:DatatypeProperty ;
    rdfs:label "has object label"@en ;
    rdfs:comment "Records the object label used by perception, simulation, or task documentation."@en ;
    rdfs:domain owl:Thing,
        cap:PhysicalObject ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf cap:hasObjectLabel ;
    owl:equivalentProperty cap:hasObjectLabel ;
    owl:sameAs cap:hasObjectLabel .

cap:hasPoseFrame a owl:DatatypeProperty ;
    rdfs:label "has pose frame"@en ;
    rdfs:comment "Links an ontology individual to a coordinate frame or pose-frame identifier used in perception, reconstruction, or simulation."@en ;
    rdfs:domain owl:Thing,
        cap:PhysicalObject ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf cap:hasPoseFrame ;
    owl:equivalentProperty cap:hasPoseFrame ;
    owl:sameAs cap:hasPoseFrame .

cap:hasReferenceObject a owl:ObjectProperty ;
    rdfs:label "has reference object"@en ;
    rdfs:comment "Relates a task to a physical object used as a spatial or semantic reference."@en ;
    rdfs:domain owl:Thing,
        cap:Task ;
    rdfs:range owl:Thing,
        cap:PhysicalObject ;
    rdfs:subPropertyOf cap:hasReferenceObject ;
    owl:equivalentProperty cap:hasReferenceObject ;
    owl:sameAs cap:hasReferenceObject .

cap:hasTargetObject a owl:ObjectProperty ;
    rdfs:label "has target object"@en ;
    rdfs:comment "Relates a task to a physical object that is directly acted upon in that task."@en ;
    rdfs:domain owl:Thing,
        cap:Task ;
    rdfs:range owl:Thing,
        cap:PhysicalObject ;
    rdfs:subPropertyOf cap:hasTargetObject ;
    owl:equivalentProperty cap:hasTargetObject ;
    owl:sameAs cap:hasTargetObject .

cap:hasTaskRole a owl:ObjectProperty ;
    rdfs:label "has task role"@en ;
    rdfs:comment "Relates a physical object to the role it plays in a task."@en ;
    rdfs:domain owl:Thing,
        cap:PhysicalObject ;
    rdfs:range owl:Thing,
        cap:TaskRole ;
    rdfs:subPropertyOf cap:hasTaskRole ;
    owl:equivalentProperty cap:hasTaskRole ;
    owl:sameAs cap:hasTaskRole .

