cap:group03 a owl:Ontology ;
    rdfs:label "AI Capstone 2026 - Group 03 Semantic Grounding Ontology"@en ;
    dcterms:created "2026-05-31"^^xsd:date ;
    dcterms:creator g03:group03 ;
    dcterms:description "A group ontology that grounds perceived task objects (cups, cutlery, plate, toy blocks, basket) as typed, role-bearing, affordance-carrying individuals, so that an OWL DL reasoner can infer which objects are graspable."@en ;
    dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
    dcterms:title "AI Capstone 2026 - Group 03 Semantic Grounding Ontology"@en ;
    vann:preferredNamespacePrefix "g03" ;
    vann:preferredNamespaceUri "https://hcis.io/ontology/aicapstone/2026/group03/" ;
    rdfs:comment "Group 03 submission for Homework 5. Imports the shared course vocabulary, supplies the OWL definition of cap:GraspableObject, and declares the environment instances used to infer graspability."@en ;
    owl:imports <https://hcis.io/ontology/aicapstone/2026> ;
    owl:sameAs cap:group03 .

g03:basket01 a _:n492e73933d01486ca9ad9b662b0d511cb7,
        owl:Thing,
        cap:Basket,
        cap:PhysicalObject ;
    rdfs:label "basket 01"@en ;
    rdfs:comment "The basket instance that receives toy blocks in the toy-block-collection task."@en ;
    owl:sameAs g03:basket01 ;
    cap:hasAffordance g03:aff_basket01_contain ;
    cap:hasColor "brown" ;
    cap:hasObjectLabel "basket" ;
    cap:hasPoseFrame "world/object_basket" ;
    cap:hasTaskRole cap:ContainerTarget .

g03:blockCollectionTask a owl:Thing,
        cap:ManipulationTask,
        cap:Task ;
    rdfs:label "toy block collection task"@en ;
    rdfs:comment "The baseline toy-block-collection task instance for Group 03."@en ;
    owl:sameAs g03:blockCollectionTask ;
    cap:hasTargetObject g03:block01,
        g03:block02 .

g03:cupStackingTask a owl:Thing,
        cap:ManipulationTask,
        cap:Task ;
    rdfs:label "cup stacking task"@en ;
    rdfs:comment "The baseline cup-stacking task instance for Group 03."@en ;
    owl:sameAs g03:cupStackingTask ;
    cap:hasTargetObject g03:blueCup01,
        g03:pinkCup01 .

g03:cutleryTask a owl:Thing,
        cap:ManipulationTask,
        cap:Task ;
    rdfs:label "cutlery arrangement task"@en ;
    rdfs:comment "The baseline cutlery-arrangement task instance for Group 03."@en ;
    owl:sameAs g03:cutleryTask ;
    cap:hasReferenceObject g03:plate01 ;
    cap:hasTargetObject g03:fork01,
        g03:knife01 .

() owl:sameAs () .

foaf:Group owl:sameAs foaf:Group .

<https://hcis.io/ontology/aicapstone/2026> a owl:Ontology ;
    rdfs:label "AI Capstone 2026 Course Ontology"@en ;
    dcterms:created "2026-05-22"^^xsd:date ;
    dcterms:creator cap:ccyont ;
    dcterms:description "This ontology defines a compact course vocabulary for representing physical task objects, task roles, manipulation affordances, grounding identifiers, and inferable graspability in the AI Capstone 2026 Physical AI project."@en ;
    dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
    dcterms:title "AI Capstone 2026 Course Ontology"@en ;
    vann:preferredNamespacePrefix "cap" ;
    vann:preferredNamespaceUri "https://hcis.io/ontology/aicapstone/2026/" ;
    rdfs:comment "A reduced educational ontology profile for semantic and affordance grounding of graspable objects in the AI Capstone 2026 course project."@en ;
    owl:sameAs <https://hcis.io/ontology/aicapstone/2026> .

cap:ccyont a foaf:Person ;
    owl:sameAs cap:ccyont ;
    foaf:mbox <mailto:ccy@hptp.org> ;
    foaf:name "Chun-yien Chang"@en .

g03:aff_basket01_contain a owl:Thing,
        cap:Affordance,
        cap:ContainmentAffordance ;
    rdfs:label "containment affordance of basket 01"@en ;
    rdfs:comment "The containment affordance of basket 01: the basket can receive and hold toy blocks; this is why the basket is a container rather than a grasp target."@en ;
    owl:sameAs g03:aff_basket01_contain .

g03:aff_block01_grasp a owl:Thing,
        cap:Affordance,
        cap:GraspingAffordance ;
    rdfs:label "grasping affordance of toy block 01"@en ;
    rdfs:comment "The grasping affordance of toy block 01: the block can be grasped and lifted by the robot gripper for collection into the basket."@en ;
    owl:sameAs g03:aff_block01_grasp .

g03:aff_block02_grasp a owl:Thing,
        cap:Affordance,
        cap:GraspingAffordance ;
    rdfs:label "grasping affordance of toy block 02"@en ;
    rdfs:comment "The grasping affordance of toy block 02: the block can be grasped and lifted by the robot gripper for collection into the basket."@en ;
    owl:sameAs g03:aff_block02_grasp .

g03:aff_blueCup01_grasp a owl:Thing,
        cap:Affordance,
        cap:GraspingAffordance ;
    rdfs:label "grasping affordance of blue cup 01"@en ;
    rdfs:comment "The grasping affordance of blue cup 01: the cup can be grasped, held, and lifted by the robot gripper."@en ;
    owl:sameAs g03:aff_blueCup01_grasp .

g03:aff_blueCup01_stack a owl:Thing,
        cap:Affordance,
        cap:StackabilityAffordance ;
    rdfs:label "stackability affordance of blue cup 01"@en ;
    rdfs:comment "The stackability affordance of blue cup 01: the cup can be stacked with another cup in the cup-stacking task."@en ;
    owl:sameAs g03:aff_blueCup01_stack .

g03:aff_fork01_grasp a owl:Thing,
        cap:Affordance,
        cap:GraspingAffordance ;
    rdfs:label "grasping affordance of fork 01"@en ;
    rdfs:comment "The grasping affordance of fork 01: the fork can be grasped and repositioned by the robot gripper in the cutlery-arrangement task."@en ;
    owl:sameAs g03:aff_fork01_grasp .

g03:aff_knife01_grasp a owl:Thing,
        cap:Affordance,
        cap:GraspingAffordance ;
    rdfs:label "grasping affordance of knife 01"@en ;
    rdfs:comment "The grasping affordance of knife 01: the knife can be grasped and repositioned by the robot gripper in the cutlery-arrangement task."@en ;
    owl:sameAs g03:aff_knife01_grasp .

g03:aff_pinkCup01_grasp a owl:Thing,
        cap:Affordance,
        cap:GraspingAffordance ;
    rdfs:label "grasping affordance of pink cup 01"@en ;
    rdfs:comment "The grasping affordance of pink cup 01: the cup can be grasped, held, and lifted by the robot gripper."@en ;
    owl:sameAs g03:aff_pinkCup01_grasp .

g03:aff_pinkCup01_stack a owl:Thing,
        cap:Affordance,
        cap:StackabilityAffordance ;
    rdfs:label "stackability affordance of pink cup 01"@en ;
    rdfs:comment "The stackability affordance of pink cup 01: the cup can be stacked with another cup in the cup-stacking task."@en ;
    owl:sameAs g03:aff_pinkCup01_stack .

g03:aff_plate01_support a owl:Thing,
        cap:Affordance,
        cap:SupportAffordance ;
    rdfs:label "support affordance of plate 01"@en ;
    rdfs:comment "The support affordance of plate 01: the plate can support cutlery placed on it; this is why the plate is a placement reference rather than a grasp target."@en ;
    owl:sameAs g03:aff_plate01_support .

g03:block01 a _:n492e73933d01486ca9ad9b662b0d511cb1,
        _:n492e73933d01486ca9ad9b662b0d511cb3,
        _:n492e73933d01486ca9ad9b662b0d511cb4,
        _:n492e73933d01486ca9ad9b662b0d511cb6,
        _:ncd72a4edb44449d99e4ad2c7dde5ef7bb1,
        _:ncd72a4edb44449d99e4ad2c7dde5ef7bb2,
        owl:Thing,
        cap:GraspableObject,
        cap:PhysicalObject,
        cap:ToyBlock ;
    rdfs:label "toy block 01"@en ;
    rdfs:comment "A toy block to be collected into the basket."@en ;
    owl:sameAs g03:block01 ;
    cap:canBeManipulatedBy g03:gripper01 ;
    cap:hasAffordance g03:aff_block01_grasp ;
    cap:hasApproxWidth 0.04 ;
    cap:hasColor "red" ;
    cap:hasObjectLabel "toy_block" ;
    cap:hasPoseFrame "world/object_block_01" ;
    cap:hasTaskRole cap:CollectableObject .

